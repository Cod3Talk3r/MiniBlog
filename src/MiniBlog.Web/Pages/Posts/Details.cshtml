@page "{id:int}"
@model MiniBlog.Web.Pages.Posts.DetailsModel
@{
    ViewData["Title"] = Model.Post?.Title;
}

<h2>@Model.Post?.Title</h2>
<p class="text-muted">توسط @Model.Post?.AuthorName — @Model.Post?.CreatedAt.ToString("yyyy-MM-dd")</p>
<p>@Model.Post?.Content</p>

<hr />
<h4>کامنت‌ها</h4>

@foreach (var comment in Model.Comments)
{
    <div class="border-bottom py-2">
        <strong>@comment.AuthorName</strong> — @comment.CreatedAt.ToString("yyyy-MM-dd HH:mm")
        <p>@comment.Text</p>
    </div>
}

@if (User.Identity?.IsAuthenticated == true)
{
    <form method="post" class="mt-3">
        <textarea asp-for="CommentText" class="form-control" rows="3" placeholder="Comment..."></textarea>
        <button type="submit" class="btn btn-secondary mt-2">Submit</button>
    </form>
}
else
{
    <p><a asp-page="/Account/Login">Login</a> For Comment.</p>
}