@page
@model MiniBlog.Web.Pages.Posts.IndexModel
@{
    ViewData["Title"] = "Posts";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>Posts‌</h2>
    @if (User.Identity?.IsAuthenticated == true)
    {
        <a asp-page="/Posts/Create" class="btn btn-primary">New Post</a>
    }
</div>

<form method="get" class="mb-3">
    <input type="text" name="search" value="@Model.Search" placeholder="Search..." class="form-control" />
</form>

@foreach (var post in Model.Posts)
{
    <div class="card mb-2">
        <div class="card-body">
            <h5><a asp-page="/Posts/Details" asp-route-id="@post.Id">@post.Title</a></h5>
            <p class="text-muted">By @post.AuthorName — @post.CreatedAt.ToString("yyyy-MM-dd") — @post.CommentsCount Comments</p>
        </div>
    </div>
}

@if (!Model.Posts.Any())
{
    <p>Posts Not Found!</p>
}